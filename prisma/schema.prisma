generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  TEAM_MANAGER
  PLAYER
  REFEREE
}

enum SportType {
  FUTBOL_11
  FUTSAL
  FUTBOL_7
  FUTBOL_SALA
  BALONMANO
  BALONCESTO
  VOLEY
  VOLEY_PLAYA
  TENIS_MESA
  TENIS
  BEACH_TENNIS
  AJEDREZ
  ATLETISMO
  DEPORTE_GENERICO
  DISPAROS
  BATTLE_ROYALE
  MOBA_LOL
  MOBA_DOTA
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Plan {
  PEQUENO
  INTERMEDIARIO
  GRANDE
  PROFESIONAL
}

enum ClassificationCriterion {
  PUNTOS
  GOLES
  GOLES_A_FAVOR
  RESULTADOS_ENTRE_SI
  TARJETAS_AMARILLAS
  TARJETAS_ROJAS
  W_O
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(TEAM_MANAGER)
  avatar    String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournaments  Tournament[]
  teams        Team[]       @relation("TeamManager")
  player       PlayerProfile?

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Tournament {
  id                 String           @id @default(cuid())
  name               String
  description        String?
  sportType          SportType
  status             TournamentStatus @default(DRAFT)
  format             String           @default("liga") // 'unico' o 'categorias'
  phaseSystem        String           @default("TODOS_CONTRA_TODOS") // 'TODOS_CONTRA_TODOS', 'LIGA_ELIMINATORIA', 'ELIMINATORIA'
  startDate          DateTime
  endDate            DateTime
  registrationEnd    DateTime?
  maxTeams           Int              @default(16)
  minPlayers         Int              @default(7)
  maxPlayersPerTeam  Int              @default(22)
  logo               String?
  banner             String?
  customUrl          String?          @unique
  plan               Plan             @default(PEQUENO)
  maxPlayersLimit    Int              @default(300)
  maxSponsors        Int              @default(3)
  classificationCriteria String       @default("PUNTOS,GOLES,GOLES_A_FAVOR,RESULTADOS_ENTRE_SI,TARJETAS_AMARILLAS,TARJETAS_ROJAS,W_O")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organizerId        String

  organizer   User          @relation(fields: [organizerId], references: [id])
  categories  Category[]
  teams       TournamentTeam[]
  matches     Match[]
  sponsors    Sponsor[]
  news        News[]
  messages    Message[]
}

model Category {
  id            String    @id @default(cuid())
  name          String
  description   String?
  minAge        Int?
  maxAge        Int?
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  
  matches   Match[]
  standings Standings[]
}

model TournamentTeam {
  id           String     @id @default(cuid())
  tournamentId String
  teamId       String
  registeredAt DateTime   @default(now())
  status       String     @default("active")

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id])
}

model Team {
  id          String    @id @default(cuid())
  name        String
  logo        String?
  color       String?
  coach       String?
  managerId   String
  manager     User      @relation("TeamManager", fields: [managerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  players         TeamPlayer[]
  teamMembers    TeamMember[]
  homeMatches     Match[]       @relation("HomeTeam")
  awayMatches     Match[]       @relation("AwayTeam")
  tournamentTeams TournamentTeam[]
  standings       Standings[]
  messages        Message[]
  matchEvents     MatchEvent[]
}

enum MemberRole {
  PLAYER
  COACH
  ASSISTANT
  TECHNICAL
}

model TeamMember {
  id        String    @id @default(cuid())
  teamId    String
  name      String
  role      MemberRole
  number    Int?
  phone    String?
  isActive Boolean  @default(true)
  createdAt DateTime  @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  matchEventsAsPlayer MatchEvent[] @relation("EventPlayer")
  matchEventsAsAssist MatchEvent[] @relation("EventAssist")
}

model PlayerProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  dni           String    @unique
  dateOfBirth   DateTime
  nationality   String?
  position      String?
  photo         String?
  createdAt     DateTime  @default(now())

  teamPlayers TeamPlayer[]
  goals      Goal[]
  sanctions  Sanction[]
}

model TeamPlayer {
  id        String         @id @default(cuid())
  teamId    String
  playerId  String
  number    Int?
  isCaptain Boolean        @default(false)
  isActive  Boolean        @default(true)
  joinedAt  DateTime       @default(now())

  team   Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Match {
  id           String       @id @default(cuid())
  tournamentId String
  categoryId   String?
  homeTeamId   String?
  awayTeamId   String?
  homeScore    Int?
  awayScore    Int?
  status       MatchStatus  @default(SCHEDULED)
  matchDate    DateTime
  roundName    String
  phaseName    String?      @default("Primera Fase")
  groupName    String?      
  advantageTeamId String?
  location     String?
  referee      String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tournament Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  category   Category?   @relation(fields: [categoryId], references: [id])
  homeTeam   Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])

  goals      Goal[]
  events     MatchEvent[]
  report     MatchReport?
}

model Goal {
  id         String   @id @default(cuid())
  matchId    String
  playerId   String
  teamId     String
  isOwnGoal  Boolean @default(false)
  minute     Int?
  createdAt  DateTime @default(now())

  match  Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player PlayerProfile @relation(fields: [playerId], references: [id])
}

model MatchEvent {
  id          String   @id @default(cuid())
  matchId     String
  teamId      String
  playerId    String?
  assistId    String?
  type        String   // 'GOAL', 'YELLOW_CARD', 'RED_CARD', 'OWN_GOAL', 'SUB_IN', 'SUB_OUT'
  timeType    String?  // '1°', '2°', '3°', '4°', 'PRORROGA'
  minute      Int?
  second      Int?
  detail      String?  @db.Text
  createdAt   DateTime @default(now())

  match       Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team        Team        @relation(fields: [teamId], references: [id])
  player      TeamMember? @relation("EventPlayer", fields: [playerId], references: [id])
  assist      TeamMember? @relation("EventAssist", fields: [assistId], references: [id])
}

model MatchReport {
  id          String   @id @default(cuid())
  matchId     String   @unique
  summary     String?
  incidents   String?
  attendance  Int?
  weather     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Standings {
  id            String  @id @default(cuid())
  categoryId    String
  teamId        String
  played        Int     @default(0)
  won           Int     @default(0)
  drawn         Int     @default(0)
  lost          Int     @default(0)
  goalsFor      Int     @default(0)
  goalsAgainst  Int     @default(0)
  points        Int     @default(0)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Sanction {
  id          String    @id @default(cuid())
  playerId    String
  type        String
  reason      String
  startDate   DateTime
  endDate     DateTime?
  matches     Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  player PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id            String    @id @default(cuid())
  name          String
  logo          String?
  website       String?
  tier          String    @default("bronze")
  tournamentId  String
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model News {
  id            String    @id @default(cuid())
  title         String
  content       String
  image         String?
  tournamentId  String
  publishedAt   DateTime  @default(now())
  isActive      Boolean   @default(true)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model Message {
  id            String    @id @default(cuid())
  content       String
  tournamentId  String?
  senderId      String
  receiverId    String
  teamId        String?
  isRead        Boolean   @default(false)
  createdAt     DateTime  @default(now())

  tournament Tournament? @relation(fields: [tournamentId], references: [id])
  sender     User        @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User        @relation("ReceivedMessages", fields: [receiverId], references: [id])
  team       Team?       @relation(fields: [teamId], references: [id])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}